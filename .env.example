# CTE Time — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env && nano .env
#
# WARNING: Never commit .env to version control. It is in .gitignore.

# Required: Generate a 64-character hex string:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Database path (default: cte_time.db in the app directory)
# DATABASE_PATH=/opt/cte-time/data/cte_time.db

# Server bind address and port (default: 127.0.0.1:8000)
# HOST=127.0.0.1
# PORT=8000

# Display timezone for student/teacher UI (default: America/Denver)
# DISPLAY_TIMEZONE=America/Denver

# Set to "true" in production (enforces HTTPS-only sessions)
# IS_PRODUCTION=true

# Session configuration (default: 8h max age, lax same-site)
# SESSION_MAX_AGE=28800
# SESSION_SAME_SITE=lax

# Rate limiting (default: 60 requests per 60-second window)
# RATE_LIMIT_MAX_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60

# Week start day: 0=Monday, 6=Sunday (Python weekday convention, default: 0)
# WEEK_START_DAY=0

# Admin bootstrap — set these on first run to create the initial admin account.
# Once seeded, they can be removed or changed. Both must be set together.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=<strong-password>

# Backup directory (default: /opt/cte-time/backups)
# BACKUP_DIR=/opt/cte-time/backups

# Backup retention in days (default: 90)
# BACKUP_RETENTION_DAYS=90

# Log directory (default: /var/log/cte-time)
# LOG_DIR=/var/log/cte-time
